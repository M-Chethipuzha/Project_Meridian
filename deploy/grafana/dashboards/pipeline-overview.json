{
  "title": "Meridian Pipeline Overview",
  "version": 1,
  "panels": [
    {
      "title": "Events Published (rate)",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(meridian_events_published_total[1m])",
          "legendFormat": "{{service}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Events Consumed (rate)",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(meridian_events_consumed_total[1m])",
          "legendFormat": "{{service}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Error Rate",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(meridian_events_failed_total[1m])",
          "legendFormat": "{{service}} {{type}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "title": "Publish Latency (p50/p95/p99)",
      "type": "graph",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(meridian_publish_duration_seconds_bucket[1m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(meridian_publish_duration_seconds_bucket[1m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(meridian_publish_duration_seconds_bucket[1m]))",
          "legendFormat": "p99"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "title": "Consume Latency (p50/p95/p99)",
      "type": "graph",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(meridian_consume_duration_seconds_bucket[1m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(meridian_consume_duration_seconds_bucket[1m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(meridian_consume_duration_seconds_bucket[1m]))",
          "legendFormat": "p99"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "title": "Consumer Lag",
      "type": "graph",
      "targets": [
        {
          "expr": "meridian_consumer_lag_messages",
          "legendFormat": "lag"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    },
    {
      "title": "Batch Size",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(meridian_batch_size_events_bucket[1m])",
          "legendFormat": "{{le}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 }
    },
    {
      "title": "Batch Write Latency (p50/p95/p99)",
      "type": "graph",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(meridian_batch_write_duration_seconds_bucket[1m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(meridian_batch_write_duration_seconds_bucket[1m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(meridian_batch_write_duration_seconds_bucket[1m]))",
          "legendFormat": "p99"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 }
    }
  ],
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" }
}
