{
  "title": "Meridian Lag Monitoring",
  "version": 1,
  "panels": [
    {
      "title": "Consumer Lag (messages)",
      "type": "graph",
      "targets": [
        {
          "expr": "meridian_consumer_lag_messages",
          "legendFormat": "consumer lag"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "yaxes": [
        { "label": "Messages", "format": "short" },
        { "show": false }
      ]
    },
    {
      "title": "Throughput Comparison (events/s)",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(meridian_events_published_total[1m])",
          "legendFormat": "publish rate"
        },
        {
          "expr": "rate(meridian_events_consumed_total[1m])",
          "legendFormat": "consume rate"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 }
    },
    {
      "title": "Error Breakdown",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(meridian_events_failed_total[1m])",
          "legendFormat": "{{type}}"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 }
    }
  ],
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" }
}
